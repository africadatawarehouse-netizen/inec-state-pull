{
  "headers": [
    {
      "source": "/dashboard/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/output/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, max-age=0, must-revalidate" }
      ]
    }
  ]
}
